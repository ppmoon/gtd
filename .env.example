# Feishu Bot（可选）
FEISHU_APP_ID=cli_xxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# LLM — LiteLLM 统一接口
# 模型格式: provider/model，支持 100+ 提供商
# 示例: anthropic/claude-sonnet-4-6, openai/gpt-4o, openai/deepseek-v3
# 设为 mock 可免 API key 用关键词启发式测试
LLM_MODEL=anthropic/claude-sonnet-4-6
LLM_API_KEY=sk-ant-xxxxxxxxxxxxxxxx
# LLM_BASE_URL=  # 可选，自定义代理地址
